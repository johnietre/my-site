{{define "style"}}
<link rel="stylesheet" href="./static/css/home.css">
{{end}}

{{define "main"}}
<main class="main">

<header>

<h1>Johnie "Tre" Rodgers</h1>

</header>

<section>
  <div class="home-tldr">
    <div class="home-tldr-section">
      <div class="home-tldr-subsection">
        <div>
          <h2 class="home-header">About Me</h2>
          <hr class="header-separator">
        </div>
        <p>
        I am a self-taught programmer with interests in financial technology (fintech), mathematics/statistics, and psychology. Some of my hobbies include listening to music, playing chess, and touching a piano once ever blue moon. I like Liebstraum No. 3, R&amp;B, and nighttime driving.
        </p>
        <a href="./about" class="button home-tldr-button">
          Read More
        </a>
      </div>
      <div class="home-tldr-subsection">
        <div>
          <h2 class="home-header">WIPs</h2>
          <hr class="header-separator">
        </div>
        <ul style="width:100%">
          <li>APP: a collection of classic puzzle games, each with slight twist</li>
          <li>APP: a way to help track your day</li>
          <li>A blog</li>
          <li>This website</li>
          <li>Android releases of current apps</li>
        </ul>
      </div>
    </div>
    <div class="home-tldr-section">
      <div>
        <h2 class="home-header">Products</h2>
        <hr class="header-separator">
      </div>
        {{with .Data}}
          {{if .Products}}
            <div class="home-item-cards">
              {{range .Products}}
              <div class="card home-item-card home-product">
                <h3 class="home-item-card-title">{{.Name}}</h3>
                <div>
                  <!--<h4>Description</h4>-->
                  <p class="description home-item-card-description home-product-description">
                  {{if .Description}}
                  {{.Description}}
                  {{else}}
                  No description available.
                  {{end}}
                  </p>
                </div>
              </div>
              {{end}}
            </div>
          {{else}}
          <div>No products to show, I guess :/</div>
          {{end}}
        {{end}}
        <a href="./products" style="margin-top:3px" class="button home-tldr-button">
          See More
        </a>
      </div>
    </div>
  </div>
</section>

{{with .Data}}
<section>
<div class="home-repos-div">
  <div>
    <h2 class="home-header">Recent Repositories</h2>
    <hr class="header-separator">
  </div>
  {{if .Repos}}
    <div class="home-item-cards home-repos">
      {{range .Repos}}
      <div class="card home-item-card">
        <h3>
          <a class="home-item-card-title" href="{{.HtmlUrl}}">
            {{.Name}}
          </a>
        </h3>
        <!--
        <div class="spacer"></div>
        -->
        <div>
          <!--<h4>Description</h4>-->
          <p class="description home-item-card-description">
          {{if .Description}}
            {{.Description}}
          {{else}}
            No description available.
          {{end}}
          </p>
        </div>
      </div>
      {{end}}
    </div>
  {{else}}
    <div>No repos to show, I guess :/</div>
  {{end}}
</div>
</section>
{{end}}

<main>
{{end}}
