{{define "style"}}
<link rel="stylesheet" href="./static/css/home.css">
{{end}}

{{define "main"}}
<h1>Johnie "Tre" Rodgers</h1>

<section>
  <div>
    <h2 style="">About Me: TLDR</h2>
    <hr style="width:100px;color:aqua"/>
  </div>
  <p>I am a self-taught programmer with interests in financial technology (FinTech) and mathematics/statistics.</p>
  <p>I graduated from Southern Methodist University with a major in Finance and minors in Statistics and Psychology.</p>
</section>

{{with .Data}}
<section>
<div id="repos-repos-div">
  <h2 style="margin-bottom:0">Recent Repositories</h2>
  {{if .Repos}}
    <hr style="width:100px;color:aqua"/>
    <div id="repos-repos">
      {{range .Repos}}
      <div class="repos-repo">
        <h3>
          <a style="color:aqua" class="repos-repo-title" href="{{.HtmlUrl}}">
            {{.Name}}
          </a>
        </h3>
        <!--
        <div class="spacer"></div>
        -->
        <div>
          <h4>Description</h4>
          <p class="repos-repo-description">
          {{if .Description}}
            {{.Description}}
          {{else}}
            No description available.
          {{end}}
          </p>
        </div>
      </div>
      {{end}}
    </div>
  {{else}}
    <div>No repos to show, I guess :/</div>
  {{end}}
</div>
</section>
{{end}}
{{end}}
