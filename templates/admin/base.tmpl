<!DOCTYPE html>

<html lang="en-US">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - {{block "title" .}}3J{{end}}</title>
  <link rel="icon" type="x-icon" href="../static/favicon.ico">
  <link rel="stylesheet" href="../static/css/base.css">
  <link rel="stylesheet" href="../static/font-awesome-4.7.0/css/font-awesome.min.css">
  <script type="module" src="../static/js/base.js" defer></script>
  {{block "script" .}}{{end}}
  {{block "style" .}}{{end}}
</head>

<body>
<div id="app">

  <nav class="nav-bar">
    <div class="nav-bar-content">
      <div class="nav-bar-logo">
        <a href="../admin" title="Admin">
          <img src="../static/images/JohnieTre-trans.png" height="50" width="50"/>
        </a>
      </div>
      <div class="nav-bar-spacer" style="flex:1">
        <span style="text-align:center;color:black;width:100%;height:100%">ADMIN</span>
      </div>
      <div class="nav-bar-theme-toggle">
        <button
          id="nav-bar-theme-toggle-button"
          class="nav-bar-theme-toggle-button"
          title="Change Theme" onclick="cycleTheme()"
        >
          <span id="nav-bar-theme-toggle-icon" class="nav-bar-theme-toggle-icon fa fa-lg"></span>
        </button>
      </div>
      <div class="nav-bar-full">
        <ul class="nav-links">
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "home"}}nav-link-active{{end}}
              "
              href="../admin/home"
              title="Home"
              >Home</a></li>
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "about"}}nav-link-active{{end}}
              "
              href="../admin/about"
              title="About"
              >About</a></li>
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "blog"}}nav-link-active{{end}}
              "
              href="../admin/blog"
              title="Blog"
              >Blog</a></li>
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "journal"}}nav-link-active{{end}}
              "
              href="../admin/journal"
              title="Journal"
              >Journal</a>
          </li>
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "products"}}nav-link-active{{end}}
              "
              href="../admin/products"
              title="Products"
              >Products</a></li>
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "api"}}nav-link-active{{end}}
              "
              href="../admin/api"
              title="API"
              >API</a></li>
          <li class="nav-link-item"><a
              class="
              nav-link
              {{if eq .Active "site"}}nav-link-active{{end}}
              "
              href="../admin/site"
              title="Site"
              >Site</a></li>
          <li class="nav-link-item"><a
              class="nav-link"
              href="../admin/logout"
              title="Logout"
              >Logout</a></li>
        </ul>
      </div>

      <div class="nav-bar-mini">
        <div class="nav-bar-burger-container">
          <button
            onclick="toggleMiniPopup()"
            class="nav-bar-burger-button"
            >
            <svg
              class="nav-bar-burger-open"
              xmlns="http://www.w3.org/2000/svg"
              width="40" height="40"
              viewBox="0 0 40 40" fill="none">
              <line x1="5" x2="35" y1="10" y2="10" stroke="black" stroke-width="2"/>
              <line x1="5" x2="35" y1="20" y2="20" stroke="black" stroke-width="2"/>
              <line x1="5" x2="35" y1="30" y2="30" stroke="black" stroke-width="2"/>
            </svg>
            <svg
              class="nav-bar-burger-close"
              xmlns="http://www.w3.org/2000/svg"
              width="40" height="40"
              viewBox="0 0 40 40" fill="none"
              class="hidden">
              <line x1="10" x2="30" y1="10" y2="30" stroke="black" stroke-width="2"/>
              <line x1="10" x2="30" y1="30" y2="10" stroke="black" stroke-width="2"/>
            </svg>
          </button> 
        </div>
      </div>
    </div>
  </nav>

  <div class="nav-mini-popup" hidden>
    <ul class="nav-links">
      <li class="nav-link-item"><a
          class="
          nav-link
          {{if eq .Active "home"}}nav-link-active{{end}}
          "
          href="./home"
          title="Home"
          >Home</a></li>
      <li class="nav-link-item"><a
          class="
          nav-link
          {{if eq .Active "about"}}nav-link-active{{end}}
          "
          href="./about"
          title="About"
          >About</a></li>
      <li class="nav-link-item"><a
          class="
          nav-link
          {{if eq .Active "blog"}}nav-link-active{{end}}
          "
          href="./blog"
          title="Blog"
          >Blog</a></li>
      <li class="nav-link-item"><a
          class="
          nav-link
          {{if eq .Active "journal"}}nav-link-active{{end}}
          "
          href="./journal"
          title="Journal"
          >Journal</a>
      </li>
      <li class="nav-link-item"><a
          class="
          nav-link
          {{if eq .Active "products"}}nav-link-active{{end}}
          "
          href="./products"
          title="Products"
          >Products</a></li>
    </ul>
  </div>

  <div id="main" class="main-container">
  {{block "main" .}}{{end}}
  </div>

  <footer class="footer">
    <div class="footer-content">
      <div class="copyright">© 2023 - 2025 JohnieTre</div>
      <div class="footer-links">
        <div class="nav-link-item footer-link-item">
          <a
            class="
            footer-link
            nav-link
            {{if eq .Active "about"}}nav-link-active{{end}}
            "
            href="./about"
            title="About"
          >About</a>
        </div>
        <div class="nav-link-item footer-link-item">
          <a
            class="
            footer-link
            nav-link
            {{if eq .Active "privacy"}}nav-link-active{{end}}
            "
            href="./privacy"
            title="Privacy"
          >Privacy</a>
        </div>
        <div class="nav-link-item footer-link-item">
          <a
            class="
            footer-link
            nav-link
            {{if eq .Active "terms"}}nav-link-active{{end}}
            "
            href="./terms"
            title="Terms"
          >Terms</a>
        </div>
      </div>
      <div class="social-links">
        <div>
          <a
            href="https://github.com/johnietre"
            target="_blank" class="social-icon"
          ><span class="fa fa-github fa-lg"></span></a>
        </div>
        <div>
          <a
            href="https://www.linkedin.com/in/johnie-rodgers-48748114b/"
            target="_blank" class="social-icon"
          ><span class="fa fa-linkedin fa-lg"></span></a>
        </div>
      </div>
    </div>
  </footer>

</div>

</body>

</html>
